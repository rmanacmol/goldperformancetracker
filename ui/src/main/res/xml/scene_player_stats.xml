<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetEnd="@+id/expanded"
        motion:constraintSetStart="@+id/collapsed"
        motion:duration="350"
        motion:motionInterpolator="easeInOut" />

    <ConstraintSet android:id="@+id/collapsed">
        <Constraint
            android:id="@id/playerAvatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toTopOf="parent" />
        <Constraint
            android:id="@id/playerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintStart_toEndOf="@id/playerAvatar"
            motion:layout_constraintTop_toTopOf="@id/playerAvatar" />
        <Constraint
            android:id="@id/playerClub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            motion:layout_constraintEnd_toEndOf="@id/playerName"
            motion:layout_constraintStart_toStartOf="@id/playerName"
            motion:layout_constraintTop_toBottomOf="@id/playerName" />
        <Constraint
            android:id="@id/avgBallSpeed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toBottomOf="@id/playerAvatar" />
        <Constraint
            android:id="@id/avgLaunchAngle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="0"
            motion:layout_constraintEnd_toEndOf="@id/avgBallSpeed"
            motion:layout_constraintStart_toStartOf="@id/avgBallSpeed"
            motion:layout_constraintTop_toBottomOf="@id/avgBallSpeed" />
        <Constraint
            android:id="@id/avgCarryDistance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="0"
            motion:layout_constraintEnd_toEndOf="@id/avgBallSpeed"
            motion:layout_constraintStart_toStartOf="@id/avgBallSpeed"
            motion:layout_constraintTop_toBottomOf="@id/avgLaunchAngle" />
        <Constraint
            android:id="@id/avgSpinRate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="0"
            motion:layout_constraintEnd_toEndOf="@id/avgBallSpeed"
            motion:layout_constraintStart_toStartOf="@id/avgBallSpeed"
            motion:layout_constraintTop_toBottomOf="@id/avgCarryDistance" />
        <Constraint
            android:id="@id/detailMetricBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:alpha="0"
            motion:layout_constraintBottom_toBottomOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toBottomOf="@id/avgBallSpeed" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/expanded">
        <Constraint
            android:id="@id/playerAvatar"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toTopOf="parent" />
        <Constraint
            android:id="@id/playerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintStart_toEndOf="@id/playerAvatar"
            motion:layout_constraintTop_toTopOf="@id/playerAvatar" />
        <Constraint
            android:id="@id/playerClub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            motion:layout_constraintEnd_toEndOf="@id/playerName"
            motion:layout_constraintStart_toStartOf="@id/playerName"
            motion:layout_constraintTop_toBottomOf="@id/playerName" />
        <Constraint
            android:id="@id/avgBallSpeed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toBottomOf="@id/playerAvatar" />
        <Constraint
            android:id="@id/avgLaunchAngle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="1"
            motion:layout_constraintEnd_toEndOf="@id/avgBallSpeed"
            motion:layout_constraintStart_toStartOf="@id/avgBallSpeed"
            motion:layout_constraintTop_toBottomOf="@id/avgBallSpeed" />
        <Constraint
            android:id="@id/avgCarryDistance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="1"
            motion:layout_constraintEnd_toEndOf="@id/avgBallSpeed"
            motion:layout_constraintStart_toStartOf="@id/avgBallSpeed"
            motion:layout_constraintTop_toBottomOf="@id/avgLaunchAngle" />
        <Constraint
            android:id="@id/avgSpinRate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="1"
            motion:layout_constraintEnd_toEndOf="@id/avgBallSpeed"
            motion:layout_constraintStart_toStartOf="@id/avgBallSpeed"
            motion:layout_constraintTop_toBottomOf="@id/avgCarryDistance" />
        <Constraint
            android:id="@id/detailMetricBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:alpha="1"
            motion:layout_constraintBottom_toBottomOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toBottomOf="@id/avgSpinRate" />
    </ConstraintSet>

</MotionScene>
