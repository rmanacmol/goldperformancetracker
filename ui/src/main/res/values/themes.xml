<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GolfPerformanceTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/golf_green</item>
        <item name="colorPrimaryVariant">@color/golf_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/golf_accent</item>
        <item name="colorSecondaryVariant">@color/golf_green_light</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/golf_surface</item>
        <item name="android:textColorPrimary">@color/golf_on_surface</item>
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
